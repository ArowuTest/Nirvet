# Nirvet backend configuration (copy to .env for local dev; never commit real secrets).
NIRVET_ENV=development
NIRVET_HTTP_ADDR=:8080

# Application DB role (non-owner, RLS-bound). Created by the migrate command.
# Port 5433 matches deploy/docker-compose.yml (coexists with a local Postgres on 5432).
NIRVET_DATABASE_URL=postgres://nirvet_app:nirvet_app@localhost:5433/nirvet?sslmode=disable
# Privileged DSN used ONLY by the migrate command (owner/superuser).
NIRVET_MIGRATE_DATABASE_URL=postgres://postgres:postgres@localhost:5433/nirvet?sslmode=disable

# Auth
NIRVET_JWT_SECRET=dev-insecure-change-me
NIRVET_JWT_ISSUER=nirvet
# Browser origin allowed by CORS (the frontend dev server).
NIRVET_CORS_ORIGIN=http://localhost:3000
NIRVET_ACCESS_TTL=15m
NIRVET_REFRESH_TTL=720h

# Connector credential vault (ADR-0004). Local dev: base64 32-byte AES key (optional).
# Production: set NIRVET_KMS_KEY_NAME to a GCP KMS CryptoKey and leave the master key empty.
NIRVET_SECRET_MASTER_KEY=
NIRVET_KMS_KEY_NAME=

# AI copilot (SRS §6.12). Empty key => offline deterministic fallback (no LLM calls).
NIRVET_ANTHROPIC_API_KEY=
NIRVET_AI_MODEL=claude-sonnet-5

# Ingestion (ADR-0003)
NIRVET_INLINE_WORKER=true
NIRVET_INGEST_WORKERS=4

# First-run bootstrap (provider tenant + platform admin). Rotate before go-live.
NIRVET_BOOTSTRAP_EMAIL=admin@nirvet.local
NIRVET_BOOTSTRAP_PASSWORD=ChangeMe123!
